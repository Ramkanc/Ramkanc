  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 3 — Load BLIP captioning model"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── BLIP Captioning ───────────────────────────────────────────────────────────\n",
    "print(\"Loading BLIP captioning model...\")\n",
    "BLIP_CAP_ID = \"Salesforce/blip-image-captioning-large\"\n",
    "\n",
    "blip_cap_processor = BlipProcessor.from_pretrained(BLIP_CAP_ID)\n",
    "blip_cap_model = BlipForConditionalGeneration.from_pretrained(\n",
    "    BLIP_CAP_ID,\n",
    "    torch_dtype=DTYPE\n",
    ").to(DEVICE)\n",
    "blip_cap_model.eval()\n",
    "print(\"✓ BLIP captioning ready\")\n",
    "\n",
    "\n",
    "def generate_blip_caption(image: Image.Image, prompt: str = \"\") -> str:\n",
    "    \"\"\"Generate a descriptive caption for a PIL image using BLIP.\"\"\"\n",
    "    if image.mode != \"RGB\":\n",
    "        image = image.convert(\"RGB\")\n",
    "    inputs = blip_cap_processor(\n",
    "        images=image,\n",
    "        text=prompt if prompt else None,\n",
    "        return_tensors=\"pt\"\n",
    "    ).to(DEVICE, DTYPE)\n",
    "    with torch.no_grad():\n",
    "        ids = blip_cap_model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=120,\n",
    "            num_beams=5,\n",
    "            min_length=10,\n",
    "            repetition_penalty=1.3\n",
    "        )\n",
    "    caption = blip_cap_processor.decode(ids[0], skip_special_tokens=True)\n",
    "    return caption.strip()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 4 — Load CLIP embedder"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CLIP Embedder ─────────────────────────────────────────────────────────────\n",
    "print(\"Loading CLIP model...\")\n",
    "CLIP_ID = \"openai/clip-vit-base-patch32\"\n",
    "\n",
    "clip_processor = CLIPProcessor.from_pretrained(CLIP_ID)\n",
    "clip_model = CLIPModel.from_pretrained(CLIP_ID, torch_dtype=DTYPE).to(DEVICE)\n",
    "clip_model.eval()\n",
    "print(\"✓ CLIP embedder ready\")\n",
    "\n",
    "EMBED_DIM = 512   # CLIP ViT-B/32 embedding dimension\n",
    "\n",
    "\n",
    "def embed_image(image: Image.Image) -> np.ndarray:\n",
    "    \"\"\"Return L2-normalised CLIP image embedding (float32 numpy).\"\"\"\n",
    "    if image.mode != \"RGB\":\n",
    "        image = image.convert(\"RGB\")\n",
    "    inputs = clip_processor(images=image, return_tensors=\"pt\").to(DEVICE)\n",
    "    with torch.no_grad():\n",
    "        feat = clip_model.get_image_features(**inputs)\n",
    "    feat = feat.float().cpu().numpy()\n",
    "    faiss.normalize_L2(feat)\n",
    "    return feat   # shape (1, 512)\n",
    "\n",
    "\n",
    "def embed_text(text: str) -> np.ndarray:\n",
    "    \"\"\"Return L2-normalised CLIP text embedding (float32 numpy).\"\"\"\n",
    "    inputs = clip_processor(text=[text], return_tensors=\"pt\",\n",
    "                            padding=True, truncation=True).to(DEVICE)\n",
    "    with torch.no_grad():\n",
    "        feat = clip_model.get_text_features(**inputs)\n",
    "    feat = feat.float().cpu().numpy()\n",
    "    faiss.normalize_L2(feat)\n",
    "    return feat   # shape (1, 512)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 5 — Load BLIP ITM reranker"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── BLIP ITM Reranker ─────────────────────────────────────────────────────────\n",
    "print(\"Loading BLIP ITM reranker...\")\n",
    "BLIP_ITM_ID = \"Salesforce/blip-itm-large-coco\"\n",
    "\n",
    "blip_itm_processor = BlipProcessor.from_pretrained(BLIP_ITM_ID)\n",
    "blip_itm_model = BlipForImageTextRetrieval.from_pretrained(\n",
    "    BLIP_ITM_ID,\n",
    "    torch_dtype=DTYPE\n",
    ").to(DEVICE)\n",
    "blip_itm_model.eval()\n",
    "print(\"✓ BLIP ITM reranker ready\")\n",
    "\n",
    "\n",
    "def blip_itm_score(image: Image.Image, text: str) -> float:\n",
    "    \"\"\"Return ITM match probability (0–1) between an image and a text query.\"\"\"\n",
    "    if image.mode != \"RGB\":\n",
    "        image = image.convert(\"RGB\")\n",
    "    inputs = blip_itm_processor(\n",
    "        images=image, text=text,\n",
    "        return_tensors=\"pt\"\n",
    "    ).to(DEVICE, DTYPE)\n",
    "    with torch.no_grad():\n",
    "        out = blip_itm_model(**inputs, use_itm_head=True)\n",
    "    prob = torch.nn.functional.softmax(out.itm_score, dim=1)\n",
    "    return prob[0, 1].item()   # probability of match"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 6 — Load InstructBLIP (open-source VLM for generation)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── InstructBLIP — Open-Source VLM for Answer Generation ─────────────────────\n",
    "# Uses Vicuna-7B backbone quantised to 4-bit so it fits on T4 (16 GB VRAM)\n",
    "print(\"Loading InstructBLIP (Vicuna-7B, 4-bit)...\")\n",
    "print(\"  This may take 3-5 minutes on first run...\")\n",
    "\n",
    "INSTRUCT_BLIP_ID = \"Salesforce/instructblip-vicuna-7b\"\n",
    "\n",
    "bnb_config = BitsAndBytesConfig(\n",
    "    load_in_4bit=True,\n",
    "    bnb_4bit_compute_dtype=torch.float16,\n",
    "    bnb_4bit_use_double_quant=True,\n",
    "    bnb_4bit_quant_type=\"nf4\"\n",
    ")\n",
    "\n",
    "instruct_processor = InstructBlipProcessor.from_pretrained(INSTRUCT_BLIP_ID)\n",
    "instruct_model = InstructBlipForConditionalGeneration.from_pretrained(\n",
    "    INSTRUCT_BLIP_ID,\n",
    "    quantization_config=bnb_config,\n",
    "    device_map=\"auto\"\n",
    ")\n",
    "instruct_model.eval()\n",
    "print(\"✓ InstructBLIP VLM ready\")\n",
    "\n",
    "\n",
    "def vlm_answer(image: Image.Image, question: str, context_captions: List[str]) -> str:\n",
    "    \"\"\"Ask InstructBLIP a question about an image with caption context.\"\"\"\n",
    "    if image.mode != \"RGB\":\n",
    "        image = image.convert(\"RGB\")\n",
    "\n",
    "    context_block = \"\\n\".join([f\"- {c}\" for c in context_captions]) if context_captions else \"\"\n",
    "    prompt = (\n",
    "        f\"You are an expert visual analyst. \"\n",
    "        f\"Use the image and the following context captions from related images to answer the question.\\n\\n\"\n",
    "        f\"Context captions:\\n{context_block}\\n\\n\"\n",
    "        f\"Question: {question}\\n\"\n",
    "        f\"Answer in detail:\"\n",
    "    )\n",
    "\n",
    "    inputs = instruct_processor(\n",
    "        images=image,\n",
    "        text=prompt,\n",
    "        return_tensors=\"pt\"\n",
    "    ).to(DEVICE)\n",
    "\n",
    "    with torch.no_grad():\n",
    "        ids = instruct_model.generate(\n",
    "            **inputs,\n",
    "            do_sample=True,\n",
    "            temperature=0.7,\n",
    "            max_new_tokens=256,\n",
    "            repetition_penalty=1.2\n",
    "        )\n",
    "    answer = instruct_processor.batch_decode(ids, skip_special_tokens=True)[0]\n",
    "    # Strip the prompt echo if present\n",
    "    if \"Answer in detail:\" in answer:\n",
    "        answer = answer.split(\"Answer in detail:\")[-1].strip()\n",
    "    return answer"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 7 — FAISS index & document store"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── In-memory document store + FAISS index ────────────────────────────────────\n",
    "class VisionRAGIndex:\n",
    "    \"\"\"\n",
    "    Stores uploaded images, their BLIP captions, and CLIP embeddings.\n",
    "    Supports:\n",
    "      - add_image()     : caption + embed + add to FAISS\n",
    "      - search()        : ANN dense retrieval\n",
    "      - rerank()        : BLIP ITM cross-modal reranking\n",
    "      - query()         : full pipeline (search → rerank → VLM answer)\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, embed_dim: int = 512):\n",
    "        self.embed_dim = embed_dim\n",
    "        self.index     = faiss.IndexFlatIP(embed_dim)   # inner product = cosine on normalised vecs\n",
    "        self.images: List[Image.Image] = []\n",
    "        self.captions: List[str]       = []\n",
    "        self.filenames: List[str]      = []\n",
    "        self.embeddings: List[np.ndarray] = []\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.images)\n",
    "\n",
    "    def reset(self):\n",
    "        self.__init__(self.embed_dim)\n",
    "\n",
    "    def add_image(self, image: Image.Image, filename: str = \"image\") -> str:\n",
    "        \"\"\"Caption, embed, and index one image. Returns the generated caption.\"\"\"\n",
    "        caption = generate_blip_caption(image)\n",
    "        emb     = embed_image(image)          # (1, 512)\n",
    "\n",
    "        self.index.add(emb)\n",
    "        self.images.append(image.copy())\n",
    "        self.captions.append(caption)\n",
    "        self.filenames.append(filename)\n",
    "        self.embeddings.append(emb)\n",
    "\n",
    "        print(f\"  [{len(self)}] {filename}: {caption[:80]}...\")\n",
    "        return caption\n",
    "\n",
    "    def search(self, query: str, top_n: int = 5) -> List[int]:\n",
    "        \"\"\"Dense ANN retrieval. Returns list of index positions.\"\"\"\n",
    "        if len(self) == 0:\n",
    "            return []\n",
    "        q_emb = embed_text(query)   # (1, 512)\n",
    "        top_n = min(top_n, len(self))\n",
    "        scores, indices = self.index.search(q_emb, top_n)\n",
    "        return indices[0].tolist(), scores[0].tolist()\n",
    "\n",
    "    def rerank(self, query: str, candidates: List[int], top_k: int = 3) -> List[Tuple[int, float]]:\n",
    "        \"\"\"BLIP ITM reranker over candidate indices. Returns sorted (idx, score).\"\"\"\n",
    "        scored = []\n",
    "        for idx in candidates:\n",
    "            score = blip_itm_score(self.images[idx], query)\n",
    "            scored.append((idx, score))\n",
    "        scored.sort(key=lambda x: x[1], reverse=True)\n",
    "        return scored[:top_k]\n",
    "\n",
    "    def query(self, question: str, top_n: int = 8, top_k: int = 3) -> dict:\n",
    "        \"\"\"\n",
    "        Full RAG pipeline:\n",
    "          1. Dense retrieval (CLIP ANN)\n",
    "          2. BLIP ITM reranking\n",
    "          3. InstructBLIP generation on best image + context captions\n",
    "        \"\"\"\n",
    "        if len(self) == 0:\n",
    "            return {\"error\": \"No images indexed yet. Please upload images first.\"}\n",
    "\n",
    "        # Stage 1: Dense retrieval\n",
    "        ann_indices, ann_scores = self.search(question, top_n=top_n)\n",
    "\n",
    "        # Stage 2: BLIP ITM rerank\n",
    "        reranked = self.rerank(question, ann_indices, top_k=top_k)\n",
    "\n",
    "        # Stage 3: Assemble context & generate answer\n",
    "        best_idx   = reranked[0][0]\n",
    "        best_image = self.images[best_idx]\n",
    "        context_captions = [self.captions[idx] for idx, _ in reranked]\n",
    "\n",
    "        answer = vlm_answer(best_image, question, context_captions)\n",
    "\n",
    "        return {\n",
    "            \"answer\":           answer,\n",
    "            \"best_image\":       best_image,\n",
    "            \"best_filename\":    self.filenames[best_idx],\n",
    "            \"best_caption\":     self.captions[best_idx],\n",
    "            \"reranked_results\": [\n",
    "                {\n",
    "                    \"rank\":     i + 1,\n",
    "                    \"filename\": self.filenames[idx],\n",
    "                    \"caption\":  self.captions[idx],\n",
    "                    \"itm_score\": round(score, 4),\n",
    "                    \"image\":    self.images[idx]\n",
    "                }\n",
    "                for i, (idx, score) in enumerate(reranked)\n",
    "            ]\n",
    "        }\n",
    "\n",
    "\n",
    "# Global index instance\n",
    "rag_index = VisionRAGIndex(embed_dim=EMBED_DIM)\n",
    "print(\"✓ VisionRAGIndex initialised\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 8 — Helper: annotate image with caption overlay"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Caption overlay helper ────────────────────────────────────────────────────\n",
    "def annotate_image(image: Image.Image, caption: str, score: float = None,\n",
    "                   rank: int = None) -> Image.Image:\n",
    "    \"\"\"Draw a caption banner on top of the image for display in the gallery.\"\"\"\n",
    "    img = image.copy().convert(\"RGB\")\n",
    "    w, h = img.size\n",
    "    scale = w / 500\n",
    "    banner_h = max(60, int(50 * scale))\n",
    "\n",
    "    out = Image.new(\"RGB\", (w, h + banner_h), color=(30, 30, 40))\n",
    "    out.paste(img, (0, banner_h))\n",
    "\n",
    "    draw = ImageDraw.Draw(out)\n",
    "    try:\n",
    "        from PIL import ImageFont\n",
    "        font = ImageFont.truetype(\"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\",\n",
    "                                   max(12, int(13 * scale)))\n",
    "        small_font = ImageFont.truetype(\"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf\",\n",
    "                                         max(10, int(11 * scale)))\n",
    "    except Exception:\n",
    "        font = ImageFont.load_default()\n",
    "        small_font = font\n",
    "\n",
    "    label = f\"#{rank} ITM:{score:.3f}  \" if (rank and score) else \"\"\n",
    "    wrapped = textwrap.fill(caption, width=max(40, int(w / (7 * scale))))\n",
    "\n",
    "    draw.text((8, 4),  label,   fill=(255, 200, 80),  font=font)\n",
    "    draw.text((8, 22), wrapped, fill=(220, 220, 220), font=small_font)\n",
    "    return out\n",
    "\n",
    "print(\"✓ Annotate helper ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Cell 9 — Gradio UI (complete app)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Gradio Callbacks ──────────────────────────────────────────────────────────\n",
    "\n",
    "def cb_upload_images(files) -> Tuple[str, List]:\n",
    "    \"\"\"\n",
    "    Gradio callback — upload & index multiple images.\n",
    "    Returns (status_text, gallery_images).\n",
    "    \"\"\"\n",
    "    if not files:\n",
    "        return \"No files received.\", []\n",
    "\n",
    "    gallery = []\n",
    "    log_lines = []\n",
    "\n",
    "    for f in files:\n",
    "        try:\n",
    "            img = Image.open(f.name).convert(\"RGB\")\n",
    "            fname = Path(f.name).name\n",
    "            caption = rag_index.add_image(img, filename=fname)\n",
    "            annotated = annotate_image(img, caption)\n",
    "            gallery.append(annotated)\n",
    "            log_lines.append(f\"✓ {fname}\\n   Caption: {caption}\")\n",
    "        except Exception as e:\n",
    "            log_lines.append(f\"✗ {Path(f.name).name}: {e}\")\n",
    "\n",
    "    status = (\n",
    "        f\"Indexed {len(rag_index)} image(s) total\\n\\n\"\n",
    "        + \"\\n\".join(log_lines)\n",
    "    )\n",
    "    return status, gallery\n",
    "\n",
    "\n",
    "def cb_regenerate_caption(file) -> Tuple[str, object]:\n",
    "    \"\"\"\n",
    "    Gradio callback — generate caption for a single image WITHOUT indexing.\n",
    "    Used in the Caption tab for quick inspection.\n",
    "    \"\"\"\n",
    "    if file is None:\n",
    "        return \"Upload an image first.\", None\n",
    "    try:\n",
    "        img = Image.open(file.name).convert(\"RGB\")\n",
    "        caption = generate_blip_caption(img)\n",
    "        annotated = annotate_image(img, caption)\n",
    "        return caption, annotated\n",
    "    except Exception as e:\n",
    "        return f\"Error: {e}\", None\n",
    "\n",
    "\n",
    "def cb_query(question: str, top_n: int, top_k: int) -> Tuple[str, str, List]:\n",
    "    \"\"\"\n",
    "    Gradio callback — run full Vision RAG query.\n",
    "    Returns (answer, retrieval_summary, gallery_of_top_results).\n",
    "    \"\"\"\n",
    "    if not question.strip():\n",
    "        return \"Please enter a question.\", \"\", []\n",
    "    if len(rag_index) == 0:\n",
    "        return \"No images indexed. Go to the Index tab and upload images first.\", \"\", []\n",
    "\n",
    "    t0 = time.time()\n",
    "    result = rag_index.query(question.strip(), top_n=int(top_n), top_k=int(top_k))\n",
    "    elapsed = time.time() - t0\n",
    "\n",
    "    if \"error\" in result:\n",
    "        return result[\"error\"], \"\", []\n",
    "\n",
    "    # Format retrieval summary\n",
    "    summary_lines = [f\"Query processed in {elapsed:.1f}s | {len(rag_index)} images indexed\\n\"]\n",
    "    for r in result[\"reranked_results\"]:\n",
    "        summary_lines.append(\n",
    "            f\"Rank {r['rank']} — {r['filename']}\\n\"\n",
    "            f\"  ITM score : {r['itm_score']:.4f}\\n\"\n",
    "            f\"  Caption   : {r['caption']}\\n\"\n",
    "        )\n",
    "    summary = \"\\n\".join(summary_lines)\n",
    "\n",
    "    # Build gallery from top-k results\n",
    "    gallery = [\n",
    "        annotate_image(r[\"image\"], r[\"caption\"],\n",
    "                       score=r[\"itm_score\"], rank=r[\"rank\"])\n",
    "        for r in result[\"reranked_results\"]\n",
    "    ]\n",
    "\n",
    "    return result[\"answer\"], summary, gallery\n",
    "\n",
    "\n",
    "def cb_reset_index() -> str:\n",
    "    rag_index.reset()\n",
    "    gc.collect()\n",
    "    torch.cuda.empty_cache()\n",
    "    return \"Index cleared. Upload new images to begin.\"\n",
    "\n",
    "\n",
    "# ── Gradio Layout ─────────────────────────────────────────────────────────────\n",
    "with gr.Blocks(\n",
    "    theme=gr.themes.Soft(primary_hue=\"blue\", secondary_hue=\"sky\"),\n",
    "    title=\"Vision RAG — BLIP + InstructBLIP\"\n",
    ") as demo:\n",
    "\n",
    "    gr.Markdown(\"\"\"\n",
    "    # 🔍 Vision RAG System\n",
    "    **BLIP captioning · CLIP dense retrieval · BLIP ITM reranking · InstructBLIP VLM generation**\n",
    "\n",
    "    1. **Index tab** — upload images to build the knowledge base\n",
    "    2. **Caption tab** — inspect BLIP captions for any image\n",
    "    3. **Query tab** — ask questions, get grounded answers\n",
    "    \"\"\")\n",
    "\n",
    "    with gr.Tabs():\n",
    "\n",
    "        # ── Tab 1: Index ──────────────────────────────────────────────────────\n",
    "        with gr.TabItem(\"📁 Index images\"):\n",
    "            gr.Markdown(\"### Upload images to index\\nEach image is auto-captioned by BLIP then embedded by CLIP and stored in FAISS.\")\n",
    "\n",
    "            with gr.Row():\n",
    "                with gr.Column(scale=1):\n",
    "                    upload_btn  = gr.File(\n",
    "                        label=\"Upload images (PNG / JPG / WEBP)\",\n",
    "                        file_count=\"multiple\",\n",
    "                        file_types=[\".jpg\", \".jpeg\", \".png\", \".webp\", \".bmp\"]\n",
    "                    )\n",
    "                    index_btn   = gr.Button(\"⚡ Index images\",  variant=\"primary\")\n",
    "                    reset_btn   = gr.Button(\"🗑️ Reset index\",   variant=\"stop\")\n",
    "                    index_status = gr.Textbox(\n",
    "                        label=\"Indexing log\",\n",
    "                        lines=10, interactive=False\n",
    "                    )\n",
    "                with gr.Column(scale=2):\n",
    "                    index_gallery = gr.Gallery(\n",
    "                        label=\"Indexed images (with BLIP captions)\",\n",
    "                        columns=3, height=480\n",
    "                    )\n",
    "\n",
    "            index_btn.click(\n",
    "                fn=cb_upload_images,\n",
    "                inputs=[upload_btn],\n",
    "                outputs=[index_status, index_gallery]\n",
    "            )\n",
    "            reset_btn.click(\n",
    "                fn=cb_reset_index,\n",
    "                outputs=[index_status]\n",
    "            )\n",
    "\n",
    "        # ── Tab 2: Caption single image ────────────────────────────────────────\n",
    "        with gr.TabItem(\"📝 Caption inspector\"):\n",
    "            gr.Markdown(\"### Inspect BLIP captions\\nUpload any image to see what BLIP generates — without adding it to the index.\")\n",
    "\n",
    "            with gr.Row():\n",
    "                with gr.Column(scale=1):\n",
    "                    cap_upload  = gr.File(\n",
    "                        label=\"Upload image\",\n",
    "                        file_count=\"single\",\n",
    "                        file_types=[\".jpg\", \".jpeg\", \".png\", \".webp\"]\n",
    "                    )\n",
    "                    cap_btn     = gr.Button(\"🖊️ Generate caption\", variant=\"primary\")\n",
    "                    cap_output  = gr.Textbox(\n",
    "                        label=\"BLIP caption\",\n",
    "                        lines=4, interactive=False\n",
    "                    )\n",
    "                with gr.Column(scale=2):\n",
    "                    cap_preview = gr.Image(\n",
    "                        label=\"Annotated preview\",\n",
    "                        type=\"pil\", height=400\n",
    "                    )\n",
    "\n",
    "            cap_btn.click(\n",
    "                fn=cb_regenerate_caption,\n",
    "                inputs=[cap_upload],\n",
    "                outputs=[cap_output, cap_preview]\n",
    "            )\n",
    "\n",
    "        # ── Tab 3: Query ──────────────────────────────────────────────────────\n",
    "        with gr.TabItem(\"🤖 Query\"):\n",
    "            gr.Markdown(\"\"\"\n",
    "            ### Ask questions about your image knowledge base\n",
    "            Pipeline: **CLIP ANN → BLIP ITM rerank → InstructBLIP answer**\n",
    "            \"\"\")\n",
    "\n",
    "            with gr.Row():\n",
    "                question_box = gr.Textbox(\n",
    "                    label=\"Your question\",\n",
    "                    placeholder=\"e.g. What animals are present in the images? Which image shows outdoor scenery?\",\n",
    "                    lines=2, scale=4\n",
    "                )\n",
    "                with gr.Column(scale=1):\n",
    "                    top_n_slider = gr.Slider(\n",
    "                        minimum=3, maximum=20, value=8, step=1,\n",
    "                        label=\"ANN top-N candidates\"\n",
    "                    )\n",
    "                    top_k_slider = gr.Slider(\n",
    "                        minimum=1, maximum=5, value=3, step=1,\n",
    "                        label=\"Reranked top-k\"\n",
    "                    )\n",
    "\n",
    "            query_btn = gr.Button(\"🔍 Run Vision RAG query\", variant=\"primary\")\n",
    "\n",
    "            with gr.Row():\n",
    "                with gr.Column(scale=2):\n",
    "                    answer_box = gr.Textbox(\n",
    "                        label=\"InstructBLIP answer\",\n",
    "                        lines=8, interactive=False\n",
    "                    )\n",
    "                with gr.Column(scale=1):\n",
    "                    retrieval_box = gr.Textbox(\n",
    "                        label=\"Retrieval summary (ITM scores)\",\n",
    "                        lines=8, interactive=False\n",
    "                    )\n",
    "\n",
    "            result_gallery = gr.Gallery(\n",
    "                label=\"Top retrieved images (ranked by BLIP ITM)\",\n",
    "                columns=3, height=360\n",
    "            )\n",
    "\n",
    "            gr.Examples(\n",
    "                examples=[\n",
    "                    [\"What objects are visible in these images?\", 8, 3],\n",
    "                    [\"Which image best represents an outdoor scene?\", 8, 3],\n",
    "                    [\"Describe the colors and textures present.\", 8, 3],\n",
    "                    [\"Are there any people or animals in the images?\", 8, 3],\n",
    "                    [\"What is the main subject of the most relevant image?\", 8, 3],\n",
    "                ],\n",
    "                inputs=[question_box, top_n_slider, top_k_slider],\n",
    "            )\n",
    "\n",
    "            query_btn.click(\n",
    "                fn=cb_query,\n",
    "                inputs=[question_box, top_n_slider, top_k_slider],\n",
    "                outputs=[answer_box, retrieval_box, result_gallery]\n",
    "            )\n",
    "\n",
    "        # ── Tab 4: System info ─────────────────────────────────────────────────\n",
    "        with gr.TabItem(\"ℹ️ System info\"):\n",
    "            gr.Markdown(\"\"\"\n",
    "            ## Models loaded\n",
    "\n",
    "            | Role | Model | Purpose |\n",
    "            |------|-------|---------|\n",
    "            | Captioning | `Salesforce/blip-image-captioning-large` | Auto-describes every image |\n",
    "            | Embedder | `openai/clip-vit-base-patch32` | Dense visual + text vectors |\n",
    "            | Reranker | `Salesforce/blip-itm-large-coco` | ITM cross-modal score |\n",
    "            | Generator | `Salesforce/instructblip-vicuna-7b` (4-bit) | Grounded answer generation |\n",
    "            | Vector DB | FAISS `IndexFlatIP` | ANN search |\n",
    "\n",
    "            ## Pipeline stages\n",
    "\n",
    "            **Offline (indexing):**\n",
    "            ```\n",
    "            Image → BLIP caption → CLIP embed → FAISS index\n",
    "            ```\n",
    "\n",
    "            **Online (query):**\n",
    "            ```\n",
    "            Query text\n",
    "              → CLIP text embed\n",
    "              → FAISS ANN (top-N)\n",
    "              → BLIP ITM rerank (top-k)\n",
    "              → InstructBLIP VLM (best image + context captions)\n",
    "              → Answer\n",
    "            ```\n",
    "\n",
    "            ## Tips\n",
    "            - Index 10–100 images for best results\n",
    "            - Use descriptive natural-language questions\n",
    "            - Increase top-N for broader recall on large collections\n",
    "            - The ITM reranker picks the most semantically aligned image\n",
    "            \"\"\")\n",
    "\n",
    "# ── Launch ─────────────────────────────────────────────────────────────────────\n",
    "print(\"Launching Gradio app...\")\n",
    "demo.launch(\n",
    "    share=True,           # creates a public URL (works in Colab)\n",
    "    debug=False,\n",
    "    show_error=True\n",
    ")"
   ]
  }
 ]
}"
